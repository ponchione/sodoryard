# sirtopham configuration
# Copy this file to sirtopham.yaml and uncomment/edit values as needed.

# --- Top-level ---
# project_root: /path/to/your/project
# log_level: info                        # debug | info | warn | error
# log_format: text                       # text | json
# server_port: 8090                      # legacy top-level compatibility field
# server_host: localhost                 # legacy top-level compatibility field

# --- Server ---
server:
  # host: localhost
  # port: 8090
  # dev_mode: false
  # open_browser: true

# --- Provider Routing (doc 03) ---
routing:
  default:
    # provider: anthropic                # Default LLM provider
    # model: claude-sonnet-4-6           # Default model identifier
  fallback:
    # provider: local                    # Fallback when default is unavailable
    # model: qwen2.5-coder-7b

# providers:
#   anthropic:
#     type: anthropic
#     api_key_env: ANTHROPIC_API_KEY
#     model: claude-sonnet-4-6
#   local:
#     type: openai-compatible
#     base_url: http://localhost:8080/v1
#     model: qwen2.5-coder-7b
#   openrouter:
#     type: openai-compatible
#     base_url: https://openrouter.ai/api/v1
#     api_key_env: OPENROUTER_API_KEY
#     model: anthropic/claude-sonnet-4

# --- Code Intelligence & RAG (doc 04) ---
index:
  # include:                             # File globs to index
  #   - "**/*.go"
  #   - "**/*.sql"
  #   - "**/*.md"
  # exclude:                             # File globs to skip
  #   - "**/.git/**"
  #   - "**/vendor/**"
  #   - "**/node_modules/**"
  # max_rag_results: 30                  # Maximum RAG search results
  # max_tree_lines: 200                  # Maximum file tree lines in context
  # auto_reindex: true                   # Re-index on file changes
  # max_file_size_bytes: 51200           # 50KB per file limit
  # max_total_file_size_bytes: 524288    # 512KB total context limit

embedding:
  # base_url: "http://localhost:8081"    # Local nomic-embed-code container
  # model: "nomic-embed-code"
  # batch_size: 32
  # timeout_seconds: 30
  # query_prefix: "Represent this query for searching relevant code: "

# --- Agent Loop (doc 05) ---
agent:
  # max_iterations_per_turn: 50          # Hard stop for runaway loops
  # loop_detection_threshold: 3          # Same tool+args failures before nudge
  # tool_output_max_tokens: 50000        # Truncation limit per tool result
  # shell_timeout_seconds: 120           # Shell command timeout
  # shell_denylist:                      # Rejected shell command patterns
  #   - "rm -rf /"
  #   - "git push --force"
  # extended_thinking: true              # Enable Claude extended thinking
  # cache_system_prompt: true            # Prompt caching (Anthropic)
  # cache_assembled_context: true
  # cache_conversation_history: true

# --- Context Assembly (doc 06) ---
context:
  # max_assembled_tokens: 30000          # Hard cap on injected context
  # max_chunks: 25                       # Maximum code chunks from RAG
  # max_explicit_files: 5                # Maximum directly-fetched files
  # convention_budget_tokens: 3000       # Token reservation for conventions
  # git_context_budget_tokens: 2000      # Token reservation for git context
  # relevance_threshold: 0.35            # Minimum cosine similarity for code RAG
  # structural_hop_depth: 1              # Call graph expansion depth
  # structural_hop_budget: 10            # Max chunks from graph expansion
  # momentum_lookback_turns: 2           # Prior turns to scan for momentum
  # compression_threshold: 0.50          # Compress when history exceeds 50% of window
  # compression_head_preserve: 3         # Messages to protect at start
  # compression_tail_preserve: 4         # Messages to protect at end
  # compression_model: local             # Model for summarization
  # emit_context_debug: true             # Send context_debug events to web UI
  # store_assembly_reports: true         # Persist reports to SQLite

# --- Project Brain (doc 09) ---
brain:
  # enabled: true
  # vault_path: ~/obsidian-vaults/sirtopham-brain
  # obsidian_api_url: http://localhost:27124
  # obsidian_api_key: "your-api-key-here"

  # v0.2+ indexing / retrieval configuration retained for future use
  # embedding_model: nomic-embed-code
  # chunk_at_headings: true
  # reindex_on_startup: true
  # max_brain_tokens: 8000
  # brain_relevance_threshold: 0.30
  # include_graph_hops: true
  # graph_hop_depth: 1
  # log_brain_queries: true
