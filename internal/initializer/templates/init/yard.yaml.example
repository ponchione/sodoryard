# yard.yaml — generated by `yard init`
#
# Project: {{PROJECT_NAME}}
#
# This file was created by `yard init`. `{{PROJECT_ROOT}}` and
# `{{PROJECT_NAME}}` were substituted at generation time. Stock agent
# prompts are shipped in the binary and selected below with explicit
# `builtin:<role>` markers. You only need filesystem prompt paths if you
# want to override a built-in prompt for a role.
#
# After confirming provider/auth settings, run:
#
#   yard index --config yard.yaml
#   yard brain index --config yard.yaml
#   yard chain start --config yard.yaml --task "..."
#
# See docs/specs/13_Headless_Run_Command.md and
# docs/specs/14_Agent_Roles_and_Brain_Conventions.md for the full
# config schema documentation.

project_root: "{{PROJECT_ROOT}}"
log_level: info
log_format: text

server:
  host: localhost
  port: 8090
  dev_mode: false
  open_browser: false
  allow_external: false

routing:
  default:
    provider: codex
    model: gpt-5.5

providers:
  codex:
    type: codex
    model: gpt-5.5

index:
  include:
    - "**/*.go"
    - "**/*.py"
    - "**/*.ts"
    - "**/*.tsx"
    - "**/*.js"
    - "**/*.jsx"
    - "**/*.sql"
    - "**/*.md"
    - "**/*.yaml"
    - "**/*.yml"
    - "**/*.json"
    - "**/*.html"
    - "**/*.css"
  exclude:
    - "**/.git/**"
    - "**/.yard/**"
    - "**/node_modules/**"
    - "**/vendor/**"
    - "**/dist/**"
    - "**/build/**"
    - "**/coverage/**"
    - "**/.next/**"
    - "**/.turbo/**"
    - "**/*.min.js"

memory:
  backend: shunter
  shunter_data_dir: .yard/shunter/project-memory
  durable_ack: true
  rpc:
    transport: unix
    path: .yard/run/memory.sock

brain:
  enabled: true
  backend: shunter
  log_brain_queries: true

# Agent roles — all 13 are seeded by `yard init`. Stock roles use
# explicit `builtin:<role>` markers so the generated config is runnable
# without any external prompts directory. Replace a marker with a file path
# only if you want a custom prompt override for that role.
#
# Commands that accept roles may use either the config key or the associated
# persona name, for example `coder` or `thomas`.
#
# Roles (engine names from the railway):
#   orchestrator         — Sir Topham Hatt (sirtophamhatt.md)
#   planner              — Gordon (gordon.md)
#   epic-decomposer      — Edward (edward.md)
#   task-decomposer      — Emily (emily.md)
#   coder                — Thomas (thomas.md)
#   correctness-auditor  — Percy (percy.md)
#   quality-auditor      — James (james.md)
#   performance-auditor  — Spencer (spencer.md)
#   security-auditor     — Diesel (diesel.md)
#   integration-auditor  — Toby (toby.md)
#   test-writer          — Rosie (rosie.md)
#   resolver             — Victor (victor.md)
#   docs-arbiter         — Harold (harold.md)

agent_roles:
  orchestrator:
    system_prompt: "builtin:orchestrator"
    tools:
      - brain
    custom_tools:
      - spawn_agent
      - chain_complete
    brain_write_paths:
      - "receipts/orchestrator/**"
      - "logs/orchestrator/**"
    brain_deny_paths:
      - "specs/**"
      - "architecture/**"
      - "conventions/**"
      - "epics/**"
      - "tasks/**"
      - "plans/**"
    max_turns: 50
    max_tokens: 500000
    timeout: 60m

  coder:
    system_prompt: "builtin:coder"
    tools:
      - brain
      - file
      - git
      - shell
      - search
    brain_write_paths:
      - "receipts/coder/**"
      - "logs/coder/**"
    brain_deny_paths:
      - "specs/**"
      - "architecture/**"
      - "conventions/**"
      - "epics/**"
      - "tasks/**"
      - "plans/**"
    max_turns: 100
    max_tokens: 1000000
    timeout: 45m

  planner:
    system_prompt: "builtin:planner"
    tools:
      - brain
      - file:read
      - search
    brain_write_paths:
      - "plans/**"
      - "receipts/planner/**"
      - "logs/planner/**"
    brain_deny_paths:
      - "specs/**"
      - "architecture/**"
      - "conventions/**"
      - "epics/**"
      - "tasks/**"
    max_turns: 30
    max_tokens: 300000
    timeout: 20m

  test-writer:
    system_prompt: "builtin:test-writer"
    tools:
      - brain
      - file
      - git
      - shell
      - search
    brain_write_paths:
      - "receipts/test-writer/**"
      - "logs/test-writer/**"
    brain_deny_paths:
      - "specs/**"
      - "architecture/**"
      - "conventions/**"
      - "epics/**"
      - "tasks/**"
      - "plans/**"
    max_turns: 50
    max_tokens: 500000
    timeout: 30m

  resolver:
    system_prompt: "builtin:resolver"
    tools:
      - brain
      - file
      - git
      - shell
      - search
    brain_write_paths:
      - "receipts/resolver/**"
      - "logs/resolver/**"
    brain_deny_paths:
      - "specs/**"
      - "architecture/**"
      - "conventions/**"
      - "epics/**"
      - "tasks/**"
      - "plans/**"
    max_turns: 80
    max_tokens: 800000
    timeout: 30m

  correctness-auditor:
    system_prompt: "builtin:correctness-auditor"
    tools:
      - brain
      - file:read
      - git
      - search
    brain_write_paths:
      - "receipts/correctness-auditor/**"
      - "logs/correctness-auditor/**"
    brain_deny_paths:
      - "specs/**"
      - "architecture/**"
      - "conventions/**"
      - "epics/**"
      - "tasks/**"
      - "plans/**"
    max_turns: 30
    max_tokens: 300000
    timeout: 20m

  integration-auditor:
    system_prompt: "builtin:integration-auditor"
    tools:
      - brain
      - file:read
      - git
      - search
      - shell
    brain_write_paths:
      - "receipts/integration-auditor/**"
      - "logs/integration-auditor/**"
    brain_deny_paths:
      - "specs/**"
      - "architecture/**"
      - "conventions/**"
      - "epics/**"
      - "tasks/**"
      - "plans/**"
    max_turns: 30
    max_tokens: 300000
    timeout: 15m

  performance-auditor:
    system_prompt: "builtin:performance-auditor"
    tools:
      - brain
      - file:read
      - git
      - search
      - shell
    brain_write_paths:
      - "receipts/performance-auditor/**"
      - "logs/performance-auditor/**"
    brain_deny_paths:
      - "specs/**"
      - "architecture/**"
      - "conventions/**"
      - "epics/**"
      - "tasks/**"
      - "plans/**"
    max_turns: 30
    max_tokens: 300000
    timeout: 15m

  security-auditor:
    system_prompt: "builtin:security-auditor"
    tools:
      - brain
      - file:read
      - git
      - search
    brain_write_paths:
      - "receipts/security-auditor/**"
      - "logs/security-auditor/**"
    brain_deny_paths:
      - "specs/**"
      - "architecture/**"
      - "conventions/**"
      - "epics/**"
      - "tasks/**"
      - "plans/**"
    max_turns: 30
    max_tokens: 300000
    timeout: 15m

  quality-auditor:
    system_prompt: "builtin:quality-auditor"
    tools:
      - brain
      - file:read
      - git
      - search
    brain_write_paths:
      - "receipts/quality-auditor/**"
      - "logs/quality-auditor/**"
    brain_deny_paths:
      - "specs/**"
      - "architecture/**"
      - "conventions/**"
      - "epics/**"
      - "tasks/**"
      - "plans/**"
    max_turns: 30
    max_tokens: 300000
    timeout: 20m

  docs-arbiter:
    system_prompt: "builtin:docs-arbiter"
    tools:
      - brain
      - file:read
      - search
    brain_write_paths:
      - "conventions/**"
      - "receipts/docs-arbiter/**"
      - "logs/docs-arbiter/**"
    brain_deny_paths:
      - "specs/**"
      - "architecture/**"
      - "epics/**"
