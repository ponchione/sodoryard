  epic-decomposer:
    system_prompt: "builtin:epic-decomposer"
    tools:
      - brain
      - file:read
      - search
    brain_write_paths:
      - "epics/**"
      - "receipts/epic-decomposer/**"
      - "logs/epic-decomposer/**"
    brain_deny_paths:
      - "specs/**"
